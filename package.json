{
  "name": "drg-ai-frontend",
  "version": "1.1.0",
  "subVersion": "2026.05.22-1",
  "description": "ระบบข้อมูล CMI กลาง สำหรับการให้บริการข้อมูล CMI แก่หน่วยงานภายในกระทรวงสาธารณสุข",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4404 -o",
    "build": "rm -rf dist && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "dayjs": "^1.11.20",
    "file-saver": "^2.0.5",
    "ngx-pk-ui": "^2.17.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/file-saver": "^2.0.7",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
